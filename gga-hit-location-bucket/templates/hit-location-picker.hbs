<div class="gga-hit-location">
  <div class="gga-hit-location__shell">
    <header class="gga-hit-location__header">
      <div>
        <p class="gga-hit-location__eyebrow">GURPS GGA helper</p>
        <h2>Hit Location Bucket</h2>
        <p>Clique em uma parte do corpo para selecionar a regiao e enviar o modificador direto ao bucket.</p>
        {{#unless bucketReady}}
          <p class="gga-hit-location__warning">O GURPS Modifier Bucket nao foi encontrado nesta sessao.</p>
        {{/unless}}
        <p class="gga-hit-location__hint">A selecao anterior e substituida automaticamente.</p>
      </div>

      <div class="gga-hit-location__summary">
        <div class="gga-hit-location__summary-label">Bucket atual</div>
        <div class="gga-hit-location__summary-total">{{current.total}}</div>
        <div class="gga-hit-location__summary-count">{{current.count}} modificadores</div>
      </div>
    </header>

    <div class="gga-hit-location__grid">
      <section class="gga-hit-location__figure">
        <div
          class="gga-hit-location__bodymap"
          aria-label="Mapa corporal clicavel"
          data-action="pick-from-body"
          {{#if selectedHighlightColor}}style="--hl-selected-glow: {{selectedHighlightColor}};"{{/if}}
          {{#if selectedLocation}}data-selected-location="{{selectedLocation.id}}"{{/if}}
        >
          <img
            class="gga-hit-location__bodybase"
            src="modules/gga-hit-location-bucket/assets/form.webp"
            alt=""
            aria-hidden="true"
          />
          <img
            class="gga-hit-location__bodycolors"
            src="modules/gga-hit-location-bucket/assets/color.webp"
            alt=""
            aria-hidden="true"
          />
          <img
            class="gga-hit-location__selected-mask"
            alt=""
            aria-hidden="true"
          />
        </div>

        <div class="gga-hit-location__figure-caption">Clique na parte do corpo para adicionar o modificador correspondente.</div>
      </section>

      <aside class="gga-hit-location__sidebar">
        <div class="gga-hit-location__top-panels">
          <div class="gga-hit-location__selection">
            <h3>Selecao atual</h3>
            {{#if selectedLocation}}
              <div class="gga-hit-location__selection-card">
                <strong>{{selectedLocation.label}}</strong>
                <span>{{selectedLocation.signedMod}}</span>
              </div>
            {{else}}
              <p>Nenhuma area selecionada.</p>
            {{/if}}
          </div>

          <div class="gga-hit-location__maneuvers">
            <h3>Manobras</h3>
            <div class="gga-hit-location__maneuver-board">
              {{#each maneuverRows}}
                <div class="gga-hit-location__maneuver-row">
                  {{#each this}}
                    <div class="gga-hit-location__maneuver-column gga-hit-location__maneuver-column--{{size}}">
                      {{#each items}}
                        <button
                          type="button"
                          class="gga-hit-location__maneuver"
                          data-action="set-maneuver"
                          data-maneuver-id="{{id}}"
                          title="{{label}}"
                          aria-label="{{label}}"
                        >
                          <img src="{{icon}}" alt="" aria-hidden="true" />
                          <span>{{label}}</span>
                        </button>
                      {{/each}}
                    </div>
                  {{/each}}
                </div>
              {{/each}}
            </div>
          </div>
        </div>

        <div class="gga-hit-location__bucket">
          <h3>Itens no bucket</h3>
          {{#if current.items.length}}
            <ul>
              {{#each current.items}}
                <li>
                  <span>{{desc}}</span>
                  <strong>{{signedMod}}</strong>
                </li>
              {{/each}}
            </ul>
          {{else}}
            <p>Nenhum modificador adicionado ainda.</p>
          {{/if}}
        </div>

        <div class="gga-hit-location__actions">
          <button type="button" data-action="clear-bucket">Limpar bucket</button>
        </div>
      </aside>
    </div>
  </div>
</div>
